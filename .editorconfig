# Phase 13 v2.8.5 — light native/editor hygiene
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cpp,h,c,hpp}]
indent_style = tab
indent_size = 4

[*.{py,json,yml,yaml,md}]
indent_style = space
indent_size = 2

[*.{bat,cmd}]
end_of_line = crlf

[*.ps1]
end_of_line = crlf

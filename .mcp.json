{
  "$schema": "https://raw.githubusercontent.com/anthropics/mcp/main/schema/mcp.json",
  "mcpServers": {
    "powerspawn": {
      "command": "python",
      "args": ["-m", "powerspawn.mcp_server"],
      "env": {
        "PYTHONIOENCODING": "utf-8",
        "PYTHONUNBUFFERED": "1"
      }
    },
    "powerplan": {
      "command": "python",
      "args": ["powerspawn/powerplan/powerplan_server.py"],
      "env": {
        "PYTHONIOENCODING": "utf-8",
        "PYTHONUNBUFFERED": "1"
      }
    },
    "powerplanner-recorder": {
      "command": "python",
      "args": ["native/tools/session_mcp.py"],
      "env": {
        "PYTHONIOENCODING": "utf-8",
        "PYTHONUNBUFFERED": "1"
      }
    }
  }
}

{
  "name": "powerplanner",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Calendar-true Gantt charts you can actually present.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:template": "tsc -b && vite build --config vite.export.config.ts",
